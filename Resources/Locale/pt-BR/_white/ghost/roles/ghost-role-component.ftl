ghost-role-information-xenomorph-drone-name = -Zona xenomorpha.

ghost-role-information-xenomorph-drone-description =  Você é um drone xenomorfo, faça sua colmeia crescer.

ghost-role-information-xenomorph-hunter-name =  Caçador de xenomorph

ghost-role-information-xenomorph-hunter-description =  Você é um caçador de xenomorfos, cace humanóides e infecte-os com abraços de rosto.

ghost-role-information-xenomorph-larva-name = - Larva xenomorpha.

ghost-role-information-xenomorph-larva-description =  Você é uma larva xenomorfa, ajude sua colmeia a expandir e evoluir para uma casta superior.

ghost-role-information-xenomorph-maid-name = Xenomorph empregada doméstica

ghost-role-information-xenomorph-maid-description =  Você é uma empregada xeno, faça o trabalho mais importante na colmeia, limpe a colmeia.

ghost-role-information-xenomorph-praetorian-name = Xenomorph praetorian

ghost-role-information-xenomorph-praetorian-description =  Você é um pretoriano xenomorfo, proteja a colmeia e a rainha, e ataque o medo em seus inimigos.

ghost-role-information-xenomorph-queen-name =  Rainha xenomorfa.

ghost-role-information-xenomorph-queen-description =  Você é uma rainha xenomorfa, produza a prole e gerencie a colmeia, e o mais importante, não morra.

ghost-role-information-xenomorph-sentinel-name = Xenomorph sentinela

ghost-role-information-xenomorph-sentinel-description =  Ajude o pretoriano a defender a colmeia e atacar os humanóides se necessário.
