paper-ui-blank-page-message =  Esta página deixou em branco intencionalmente.

# Shown when paper with words examined details
paper-component-examine-detail-has-words = { CAPITALIZE(THE($paper)) }  Tem algo escrito nele.

# Shown when paper with stamps examined
paper-component-examine-detail-stamped-by = { CAPITALIZE(THE($paper)) } { CONJUGATE-HAVE($paper) }  Foi carimbado por: { $stamps }.

paper-component-illiterate =  Você é incapaz de escrever.

paper-component-illiterate-mime =  Seu voto proíbe que escreva.

paper-component-action-stamp-paper-other = { CAPITALIZE(THE($user)) } Selos { THE($target) } com { THE($stamp) }.

paper-component-action-stamp-paper-self =  Você sela. { THE($target) } com { THE($stamp) }.

# Indicator to show how full a paper is
paper-ui-fill-level = { $currentLength }/{ $maxLength }

paper-ui-save-button =  Salvem ({ $keybind })

paper-tamper-proof-modified-message =  Esta página foi escrita usando tinta à prova de adulteração.
