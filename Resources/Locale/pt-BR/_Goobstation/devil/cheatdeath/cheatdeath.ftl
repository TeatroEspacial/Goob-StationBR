cheat-death-component-examined = [color=red]  Algo lhe diz { SUBJECT($target) }  não tem medo da morte. [/color]

cheat-death-component-remaining-revives =
    { $amount ->
        [0]  Você não tem mais revive.
        [one]  Você tem um revive.
       *[other]  Você tem { $amount } Reanima à esquerda.
    }

cheat-death-component-remaining-revives-unlimited =  Você tem uma quantidade ilimitada de revive.

action-cheat-death-fail-no-lives =  Não vai escapar desta vez.

action-cheat-death-fail-not-dead =  Não pode enganar a morte enquanto estiver vivo!

action-cheat-death-holy-damage = A intervenção divina impede seu reavivamento.

action-cheated-death-dead = { $name }  Ossos consertados, feridas costuradas, órgãos arranjados tão perfeitamente.

action-cheated-death-alive = { $name }  violentamente treme, todos os tipos de feridas desaparecem em um flash de chamas.
