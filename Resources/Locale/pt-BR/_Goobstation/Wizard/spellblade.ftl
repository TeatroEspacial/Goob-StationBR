spellblade-examine-enchantment =  Está imbuído de { $name }  encantamento.

spellblade-already-enchanted-message =  Já está encantado!

spellblade-enchantment-lightning-name = [color=lightblue] relâmpago[/color]

spellblade-enchantment-lightning-desc =  Esta lâmina conduz energia arcana para se entrever entre as vítimas, e também torna o usuário imune a choques.

spellblade-enchantment-fire-name = [color=orange] Fogo![/color]

spellblade-enchantment-fire-desc =  Fogo, esta lâmina se acende ao atingir um inimigo, libertando uma bola de fogo, e também torna o mandril imune ao fogo.

spellblade-enchantment-bluespace-name = [color=blue] Espaço azul[/color]

spellblade-enchantment-bluespace-desc =  Esta lâmina cortará o tecido do espaço, transportando seu mandril a longas distâncias para atacar inimigos.

spellblade-enchantment-spacetime-name = [color=pink] espaço-tempo[/color]

spellblade-enchantment-spacetime-desc =  Esta lâmina vai cortar mais rápido, mas mais fraco, e amaldiçoará o alvo, cortando-os alguns segundos depois de não terem sido atacados para cada golpe.

spellblade-enchantment-forceshield-name = [color=cyan] Escudo de força.[/color]

spellblade-enchantment-forceshield-desc =  Esta lâmina irá protegê-lo parcialmente contra ataques e atordoa por uma curta duração depois de atingir um inimigo.
