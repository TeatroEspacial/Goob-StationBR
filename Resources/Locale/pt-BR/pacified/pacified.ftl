# With projectiles:
pacified-cannot-throw =  Não consigo me jogar { THE($projectile) } Isso pode machucar alguém!

# With embedding projectiles:
pacified-cannot-throw-embed =  Não tinha como eu jogar { THE($projectile) } Isso pode ficar alojado dentro de alguém!

# With liquid-spilling projectiles:
pacified-cannot-throw-spill =  Não posso jogar. { THE($projectile) } Isso pode derramar coisas desagradáveis em alguém!

pacified-cannot-harm-directly =  Não posso me machucar. { THE($entity) }!

pacified-cannot-harm-indirect =  Não posso danificar. { THE($entity) } Pode machucar alguém!

pacified-cannot-fire-gun =  Não posso atirar. { THE($entity) } Pode machucar alguém!
