# FTLdiskburner
cmd-ftldisk-desc =  Cria um disco de coordenadas FTL para navegar para o mapa que o EntityID dado está/em

cmd-ftldisk-help = ftldisk [EntityID]

cmd-ftldisk-no-transform =  Entidade { $destination }  Não tem componente de transformação!

cmd-ftldisk-no-map =  Entidade { $destination }  Não tem mapa!

cmd-ftldisk-no-map-comp =  Entidade { $destination }  está de alguma forma no mapa. { $map } Sem componente de mapa.

cmd-ftldisk-map-not-init =  Entidade { $destination }  está no mapa { $map }  Verifique se é seguro inicializar, então inicialize o mapa primeiro ou os jogadores ficarão presos no lugar!

cmd-ftldisk-map-paused =  Entidade { $desintation }  está no mapa { $map } Por favor, despachem o mapa primeiro ou os jogadores ficarão presos no lugar.

cmd-ftldisk-planet =  Entidade { $desintation }  está no mapa do planeta. { $map } E vai precisar de um ponto FTL.

cmd-ftldisk-already-dest-not-enabled =  Entidade { $destination }  está no mapa { $map }  Já tem um FTLDestination Component, mas não está habilitado!

cmd-ftldisk-requires-ftl-point =  Entidade { $destination }  está no mapa { $map }  Isso requer um ponto FTL para viajar!

cmd-ftldisk-hint =  Rede de mapas ID
