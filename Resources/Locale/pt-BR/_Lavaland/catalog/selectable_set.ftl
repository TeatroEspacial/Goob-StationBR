miner-weapon-selector-glaive-description =  Uma arma perfurante que tem alta velocidade e ataque em troca de danos menores.

miner-weapon-selector-hammer-name = Crusher Hammer

miner-weapon-selector-hammer-description =  Uma arma pesada que causa muitos danos em golpes lentos e poderosos pode minar o rock de forma ineficiente.
