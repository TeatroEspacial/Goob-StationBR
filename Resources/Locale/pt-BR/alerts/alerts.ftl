alerts-starving-name = [color=red]- Estou faminto.[/color]

alerts-starving-desc =  Você está desnutrido, as dores de fome fazem uma tarefa.

alerts-thirsty-name = [color=yellow]Sede[/color]

alerts-thirsty-desc =  Algo para beber seria bom agora.

alerts-parched-name = [color=red]Seca[/color]

