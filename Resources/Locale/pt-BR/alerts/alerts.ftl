alerts-vow-broken-name = Voto Quebrado

alerts-vow-broken-desc =  Você quebrou seus votos para Mimes em todos os lugares, pode falar e escrever, mas perdeu seus poderes por pelo menos 5 minutos inteiros!

alerts-pulled-name =  Puxado

