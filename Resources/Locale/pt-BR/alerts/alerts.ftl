alerts-pacified-name = [color=green]-Apaziguado.[/color]

alerts-pacified-desc =  Você está pacificado, não será capaz de prejudicar criaturas vivas.

alerts-adrenaline-name = [color=red]Adrenalina.[/color]

alerts-adrenaline-desc =  Você está cheio de adrenalina: a dor não vai te atrasar.

alerts-suit-power-name =  Poder do terno

alerts-suit-power-desc =  Quanta força tem o seu traje ninja espacial.

